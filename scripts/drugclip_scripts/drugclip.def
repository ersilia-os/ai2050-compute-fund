# Apptainer definition file for DrugCLIP molecular embedding extraction
#
# Bundles the Drug-The-Whole-Genome repo (unimol/ + dict/) and smiles_to_lmdb.py.
# Model weights are NOT baked in — they are bind-mounted at runtime from
#   /shared/drugclip-weights  →  /drugclip/data/model_weights
# (satisfying the hardcoded path in drugclip.py:1474)
#
# Build (from repo root):
#   apptainer build drugclip.sif scripts/drugclip_scripts/drugclip.def
#
# Upload to S3:
#   aws s3 cp drugclip.sif s3://ai2050-ersilia-cluster/sif-files/drugclip.sif

Bootstrap: docker
From: nvidia/cuda:12.1.1-cudnn8-devel-ubuntu20.04

# ── Bundle local files into the container ─────────────────────────────────────
# Paths are relative to the directory where `apptainer build` is run (repo root)
%files
    Drug-The-Whole-Genome/unimol                        /drugclip/unimol
    Drug-The-Whole-Genome/dict                          /drugclip/dict
    scripts/drugclip_scripts/smiles_to_lmdb.py          /drugclip/smiles_to_lmdb.py

# ── Build steps ───────────────────────────────────────────────────────────────
%post
    export DEBIAN_FRONTEND=noninteractive

    # System packages
    apt-get update -y && apt-get install -y \
        git wget curl bzip2 ca-certificates \
        libglib2.0-0 libxext6 libsm6 libxrender1 \
        build-essential && \
    rm -rf /var/lib/apt/lists/*

    # ── Miniforge (Python 3.9, conda-forge — no Anaconda ToS) ─────────────
    wget -q https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh \
        -O /tmp/miniforge.sh
    bash /tmp/miniforge.sh -b -p /opt/miniconda
    rm /tmp/miniforge.sh

    export PATH="/opt/miniconda/bin:$PATH"
    conda install -y mamba -c conda-forge
    mamba install -y python=3.9

    # ── PyTorch 2.1.2 + CUDA 12.1 ──────────────────────────────────────────
    pip install --no-cache-dir \
        torch==2.1.2 torchvision==0.16.2 torchaudio==2.1.2 \
        --index-url https://download.pytorch.org/whl/cu121

    # ── RDKit (version from Drug-The-Whole-Genome docker/requirements.txt) ─
    pip install --no-cache-dir rdkit==2023.9.5

    # ── FAISS (GPU build for CUDA 12) ───────────────────────────────────────
    pip install --no-cache-dir faiss-gpu-cu12 || \
        pip install --no-cache-dir faiss-cpu

    # ── Core scientific packages ────────────────────────────────────────────
    pip install --no-cache-dir \
        numpy \
        "scipy==1.10.1" \
        "scikit-learn==1.2.2" \
        "pandas==1.5.3" \
        lmdb \
        zstandard \
        h5py \
        tqdm \
        biopython==1.81 \
        biotite==0.37.0

    # ── Uni-Core (fairseq-based framework required by DrugCLIP) ────────────
    pip install --no-cache-dir \
        git+https://github.com/dptech-corp/Uni-Core.git

    # ── Create data dir placeholder (weights bind-mounted at runtime) ───────
    mkdir -p /drugclip/data/model_weights/6_folds

    # ── Make unimol importable ───────────────────────────────────────────────
    echo '/drugclip' > /opt/miniconda/lib/python3.9/site-packages/drugclip.pth

    # Clean conda cache
    conda clean -afy

# ── Runtime environment ───────────────────────────────────────────────────────
%environment
    export PATH="/opt/miniconda/bin:$PATH"
    export PYTHONPATH="/drugclip:$PYTHONPATH"
    export TOKENIZERS_PARALLELISM=false

# ── Default: run python from /drugclip working directory ─────────────────────
# The hardcoded weight path ./data/model_weights/6_folds/ in drugclip.py
# is resolved relative to CWD, so we must run from /drugclip.
%runscript
    cd /drugclip
    exec python "$@"

%labels
    Author ersilia
    Version 2.0
    Description DrugCLIP 768-dim molecular embedding extraction (6-fold ensemble)
